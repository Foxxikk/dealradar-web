# --- Produkce (Vercel) ---
# PostgreSQL z Neonu (pooled connection string). Bez něj se lokálně použije vestavěný pglite.
DATABASE_URL=

# Vercel Blob – úložiště fotek. Bez něj se lokálně ukládá do public/media.
BLOB_READ_WRITE_TOKEN=

# Ochrana cron endpointu /api/cron/import. Vercel ho posílá jako "Authorization: Bearer <secret>".
CRON_SECRET=

# --- Ladění scraperu (volitelné) ---
FS_MAX_ITEMS=30
FS_MAX_PAGES=3
FS_PDF_LIMIT=14
# FS_PARSE_PDF=1   # zapne stahování PDF (cena, kontakt, fotky). Na cronu pozor na časový limit funkce.
